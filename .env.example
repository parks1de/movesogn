# Google Apps Script Web App URL (publish your Apps Script as Web App and paste URL here)
NEXT_PUBLIC_SHEETS_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# HubSpot
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=YOUR_PORTAL_ID
NEXT_PUBLIC_HUBSPOT_FORM_GUID_CONTACT=YOUR_FORM_GUID
NEXT_PUBLIC_HUBSPOT_FORM_GUID_MARINE=YOUR_FORM_GUID
NEXT_PUBLIC_HUBSPOT_FORM_GUID_SYKKEL=YOUR_FORM_GUID

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Site URL (used for sitemap + OG tags)
NEXT_PUBLIC_SITE_URL=https://www.movesogn.no
